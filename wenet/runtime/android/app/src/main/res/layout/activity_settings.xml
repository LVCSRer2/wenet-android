<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Model"
        android:textSize="16sp"
        android:layout_marginBottom="8dp" />

    <RadioGroup
        android:id="@+id/modelRadioGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp">

        <RadioButton
            android:id="@+id/radioFull"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Full" />

        <RadioButton
            android:id="@+id/radioQuant"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Quantized"
            android:layout_marginStart="16dp" />

    </RadioGroup>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Visualization"
        android:textSize="16sp"
        android:layout_marginBottom="8dp" />

    <RadioGroup
        android:id="@+id/vizRadioGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp">

        <RadioButton
            android:id="@+id/radioWaveform"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Waveform" />

        <RadioButton
            android:id="@+id/radioSpectrogram"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Spectrogram"
            android:layout_marginStart="16dp" />

    </RadioGroup>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mic"
        android:textSize="16sp"
        android:layout_marginBottom="8dp" />

    <RadioGroup
        android:id="@+id/micRadioGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp">

        <RadioButton
            android:id="@+id/radioMicPhone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Phone" />

        <RadioButton
            android:id="@+id/radioMicBluetooth"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bluetooth"
            android:layout_marginStart="16dp" />

    </RadioGroup>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Play"
        android:textSize="16sp"
        android:layout_marginBottom="8dp" />

    <RadioGroup
        android:id="@+id/playRadioGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp">

        <RadioButton
            android:id="@+id/radioPlayPhone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Phone" />

        <RadioButton
            android:id="@+id/radioPlayBluetooth"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bluetooth"
            android:layout_marginStart="16dp" />

    </RadioGroup>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Audio Processing"
        android:textSize="16sp"
        android:layout_marginBottom="8dp" />

    <CheckBox
        android:id="@+id/checkAec"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="AEC (Echo Cancellation)" />

    <CheckBox
        android:id="@+id/checkNs"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="NS (Noise Suppression)" />

    <CheckBox
        android:id="@+id/checkAgc"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="AGC (Auto Gain Control)" />

    <CheckBox
        android:id="@+id/checkVad"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="VAD (Voice Activity Detection)"
        android:layout_marginBottom="24dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Slack Webhook URL"
        android:textSize="16sp"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/webhookUrlEditText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="https://hooks.slack.com/services/..."
        android:inputType="textUri"
        android:singleLine="true" />

    <Button
        android:id="@+id/saveButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Save"
        android:layout_marginTop="16dp" />

</LinearLayout>
</ScrollView>
