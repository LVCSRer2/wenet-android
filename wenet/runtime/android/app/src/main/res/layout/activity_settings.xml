<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Model"
        android:textSize="16sp"
        android:layout_marginBottom="8dp" />

    <RadioGroup
        android:id="@+id/modelRadioGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp">

        <RadioButton
            android:id="@+id/radioFull"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Full" />

        <RadioButton
            android:id="@+id/radioQuant"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Quantized"
            android:layout_marginStart="16dp" />

    </RadioGroup>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Visualization"
        android:textSize="16sp"
        android:layout_marginBottom="8dp" />

    <RadioGroup
        android:id="@+id/vizRadioGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp">

        <RadioButton
            android:id="@+id/radioWaveform"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Waveform" />

        <RadioButton
            android:id="@+id/radioSpectrogram"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Spectrogram"
            android:layout_marginStart="16dp" />

    </RadioGroup>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Audio Codec"
        android:textSize="16sp"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/radioOpus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Opus" />

            <RadioButton
                android:id="@+id/radioAac"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="AAC" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <RadioButton
                android:id="@+id/radioAmrNb"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="AMR-NB" />

            <RadioButton
                android:id="@+id/radioAacHw"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="AAC (HW)" />

        </LinearLayout>

    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Audio Processing"
        android:textSize="16sp"
        android:layout_marginBottom="8dp" />

    <CheckBox
        android:id="@+id/checkAec"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="AEC (Echo Cancellation)" />

    <CheckBox
        android:id="@+id/checkNs"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="NS (Noise Suppression)" />

    <CheckBox
        android:id="@+id/checkAgc"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="AGC (Auto Gain Control)" />

    <CheckBox
        android:id="@+id/checkVad"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="VAD (Voice Activity Detection)" />

    <TextView
        android:id="@+id/vadThresholdLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Speech Threshold: 0.50"
        android:textSize="13sp"
        android:layout_marginTop="4dp" />

    <SeekBar
        android:id="@+id/vadThresholdSeekBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="80"
        android:progress="40" />

    <TextView
        android:id="@+id/vadPreBufferLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Pre-buffer: 6 chunks (192ms)"
        android:textSize="13sp"
        android:layout_marginTop="4dp" />

    <SeekBar
        android:id="@+id/vadPreBufferSeekBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="18"
        android:progress="8" />

    <TextView
        android:id="@+id/vadTrailingSilenceLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Trailing Silence: 25 chunks (800ms)"
        android:textSize="13sp"
        android:layout_marginTop="4dp" />

    <SeekBar
        android:id="@+id/vadTrailingSilenceSeekBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="35"
        android:progress="20"
        android:layout_marginBottom="24dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Result Font Size"
        android:textSize="16sp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/resultFontSizeLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Font Size: 18sp"
        android:textSize="13sp" />

    <SeekBar
        android:id="@+id/resultFontSizeSeekBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="7"
        android:progress="3"
        android:layout_marginBottom="24dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="OpenAI API Key"
        android:textSize="16sp"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/openaiApiKeyEditText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="sk-..."
        android:inputType="textPassword"
        android:singleLine="true"
        android:layout_marginBottom="24dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Slack Webhook URL"
        android:textSize="16sp"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/webhookUrlEditText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="https://hooks.slack.com/services/..."
        android:inputType="textUri"
        android:singleLine="true" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Personal VAD"
        android:textSize="16sp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/personalVadActivationLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Activation Threshold: 0.80"
        android:textSize="13sp" />

    <SeekBar
        android:id="@+id/personalVadActivationSeekBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="100"
        android:progress="90" />

    <TextView
        android:id="@+id/personalVadDeactivationLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Deactivation Threshold: 0.50"
        android:textSize="13sp"
        android:layout_marginTop="4dp" />

    <SeekBar
        android:id="@+id/personalVadDeactivationSeekBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="100"
        android:progress="70"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="내 목소리 등록"
        android:textSize="16sp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/enrollmentStatusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="미등록"
        android:textSize="13sp"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/enrollButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="녹음 시작"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/saveButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Save"
        android:layout_marginTop="8dp" />

</LinearLayout>
</ScrollView>
