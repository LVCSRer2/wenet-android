<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:VoiceRect="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <FrameLayout
      android:id="@+id/textContainer"
      android:layout_width="0dp"
      android:layout_height="0dp"
      app:layout_constraintBottom_toTopOf="@+id/vadProbView"
      app:layout_constraintEnd_toEndOf="parent"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintTop_toTopOf="parent"
      android:layout_marginTop="16dp"
      android:layout_marginStart="8dp"
      android:layout_marginEnd="8dp">

      <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F4F4F4"
        android:fadingEdge="vertical">

        <TextView
          android:id="@+id/textView"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:padding="8dp"
          android:text=""
          android:textSize="18sp"
          android:linksClickable="true" />

      </ScrollView>

      <Button
        android:id="@+id/copyButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="8dp"
        android:textSize="9sp"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:padding="6dp"
        android:text="Copy"
        android:alpha="0.7" />

    </FrameLayout>

    <com.mobvoi.wenet.VadProbView
      android:id="@+id/vadProbView"
      android:layout_width="0dp"
      android:layout_height="0dp"
      app:layout_constraintHeight_percent="0.03"
      app:layout_constraintBottom_toTopOf="@+id/visualizationContainer"
      app:layout_constraintEnd_toEndOf="parent"
      app:layout_constraintStart_toStartOf="parent" />

    <FrameLayout
      android:id="@+id/visualizationContainer"
      android:layout_width="0dp"
      android:layout_height="0dp"
      app:layout_constraintHeight_percent="0.12"
      app:layout_constraintBottom_toTopOf="@+id/playbackLayout"
      app:layout_constraintEnd_toEndOf="parent"
      app:layout_constraintStart_toStartOf="parent">

      <com.mobvoi.wenet.VoiceRectView
        android:id="@+id/voiceRectView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        VoiceRect:RectCount="200"
        VoiceRect:RectDownColor="@color/green"
        VoiceRect:RectOffset="0"
        VoiceRect:RectSpeed="300"
        VoiceRect:RectTopColor="@color/green"
        android:visibility="visible" />

      <com.mobvoi.wenet.SpectrogramView
        android:id="@+id/spectrogramView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

      <LinearLayout
        android:id="@+id/dbRangeLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#99000000"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:visibility="gone">

        <com.google.android.material.slider.RangeSlider
          android:id="@+id/dbRangeSlider"
          android:layout_width="0dp"
          android:layout_height="16dp"
          android:layout_weight="1"
          android:minHeight="0dp"
          android:valueFrom="-40"
          android:valueTo="100"
          android:stepSize="1"
          app:values="@array/initial_db_range"
          app:thumbRadius="4dp"
          app:thumbColor="#FFFFFF"
          app:trackColorActive="#FFFFFF"
          app:trackColorInactive="#70FFFFFF"
          app:trackHeight="2dp"
          app:labelBehavior="gone" />

        <TextView
          android:id="@+id/dbRangeLabel"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_marginStart="2dp"
          android:text="dB: -20~80"
          android:textColor="#FFFFFF"
          android:textSize="9sp" />

      </LinearLayout>

    </FrameLayout>

    <LinearLayout
      android:id="@+id/playbackLayout"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:orientation="horizontal"
      android:gravity="center_vertical"
      android:paddingStart="8dp"
      android:paddingEnd="8dp"
      android:visibility="gone"
      app:layout_constraintBottom_toTopOf="@+id/button"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintEnd_toEndOf="parent">

      <Button
        android:id="@+id/playPauseButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="10sp"
        android:text="Play"
        android:minWidth="64dp"
        android:minHeight="0dp"
        android:padding="6dp" />

      <SeekBar
        android:id="@+id/seekBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp" />

      <TextView
        android:id="@+id/timeTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0:00/0:00"
        android:textSize="12sp" />

    </LinearLayout>

    <Button
      android:id="@+id/button"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:textSize="10sp"
      android:minHeight="0dp"
      android:padding="12dp"
      android:layout_marginStart="4dp"
      android:layout_marginEnd="3dp"
      android:text="Button"
      app:layout_constraintBottom_toBottomOf="parent"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintEnd_toStartOf="@+id/recordingsButton"
      app:layout_constraintHorizontal_chainStyle="spread" />

    <Button
      android:id="@+id/recordingsButton"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:textSize="10sp"
      android:minHeight="0dp"
      android:padding="12dp"
      android:layout_marginStart="3dp"
      android:layout_marginEnd="3dp"
      android:text="Recordings"
      app:layout_constraintBottom_toBottomOf="parent"
      app:layout_constraintStart_toEndOf="@+id/button"
      app:layout_constraintEnd_toStartOf="@+id/settingsButton" />

    <Button
      android:id="@+id/settingsButton"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:textSize="10sp"
      android:minHeight="0dp"
      android:padding="12dp"
      android:layout_marginStart="3dp"
      android:layout_marginEnd="4dp"
      android:text="Settings"
      app:layout_constraintBottom_toBottomOf="parent"
      app:layout_constraintStart_toEndOf="@+id/recordingsButton"
      app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
